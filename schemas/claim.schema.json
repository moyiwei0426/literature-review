{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aris-lit/claim",
  "title": "Claim",
  "type": "object",
  "additionalProperties": false,
  "required": ["claim_id", "paper_id", "claim_text", "claim_type", "evidence_chunk_ids"],
  "properties": {
    "claim_id": {"type": "string"},
    "paper_id": {"type": "string"},
    "claim_text": {"type": "string"},
    "claim_type": {"type": "string", "enum": ["performance", "methodological", "application", "theoretical"]},
    "evidence_chunk_ids": {"type": "array", "items": {"type": "string"}, "default": []},
    "confidence": {"type": ["number", "null"], "default": null}
  }
}
